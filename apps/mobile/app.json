{
  "expo": {
    "name": "Ride Together",
    "slug": "ride-together",
    "scheme": "rideteam",
    "entryPoint": "./index.js",
    "version": "0.1.0",
    "orientation": "portrait",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Ride Together uses your location to share your position with your active trip members.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Ride Together can keep your trip location updated while you ride."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "REPLACE_WITH_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "extra": {
      "eas": {
        "projectId": "7c8273de-b28f-40ab-a05b-36fdc382e418"
      }
    },
    "owner": "tranhoangha94",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7c8273de-b28f-40ab-a05b-36fdc382e418"
    }
  }
}
