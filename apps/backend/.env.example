NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
MOBILE_DEEP_LINK=rideteam://

DATABASE_URL=postgres://ride:ride@postgres:5432/ride_together
# Set to true on Railway / other managed Postgres with SSL
DATABASE_SSL=false
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OAuth client ID from Google Cloud Console (APIs & Services > Credentials).
# Must match apps/web's NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

LOCATION_UPDATE_TTL_SECONDS=120
LOCATION_RATE_LIMIT_TTL_SECONDS=3
DEFAULT_LAGGING_THRESHOLD_M=2000
OVERPASS_API_URLS=https://maps.mail.ru/osm/tools/overpass/api/interpreter,https://overpass.private.coffee/api/interpreter,https://overpass-api.de/api/interpreter
