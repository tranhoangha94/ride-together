{
  "name": "ride-together-mvp",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/backend",
    "apps/mobile",
    "apps/web",
    "packages/shared-contracts"
  ],
  "scripts": {
    "dev:backend": "npm --workspace apps/backend run start:dev",
    "dev:web": "npm --workspace apps/web run dev",
    "lint": "npm --workspaces run lint",
    "typecheck": "npm --workspaces run typecheck"
  },
  "overrides": {
    "expo-application": {
      "expo": "~54.0.0"
    },
    "@react-navigation/core": {
      "react": "19.1.0"
    },
    "@tanstack/react-query": {
      "react": "19.1.0"
    },
    "zustand": {
      "react": "19.1.0"
    },
    "react-freeze": {
      "react": "19.1.0"
    },
    "use-latest-callback": {
      "react": "19.1.0"
    },
    "use-sync-external-store": {
      "react": "19.1.0"
    }
  }
}
